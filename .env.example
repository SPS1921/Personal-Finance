# Postgres (Neon). Pooled connection for the app:
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct (unpooled) connection for migrations / prisma db push:
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_with_openssl_rand_base64_32"

# Optional — Google login. Leave blank to use the demo account fallback.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional — Supabase realtime + file storage.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
